# ================================================
# AI-Powered Job Market Analyzer — Environment Variables
# ================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# ⚠️  NEVER commit your .env file to GitHub!
# ================================================

# ── AWS Configuration ──────────────────────────
# Get these from AWS Console → IAM → Your User → Security Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_s3_bucket_name_here

# ── RapidAPI Configuration ─────────────────────
# Sign up at https://rapidapi.com → Search "JSearch" → Subscribe to free tier
RAPIDAPI_KEY=your_rapidapi_key_here

# ── OpenAI Configuration ───────────────────────
# Get from https://platform.openai.com/api-keys
# Note: Uses GPT-3.5-turbo — costs ~$0.01 per run
OPENAI_API_KEY=your_openai_api_key_here

# ── Optional Configuration ─────────────────────
LOG_LEVEL=INFO
